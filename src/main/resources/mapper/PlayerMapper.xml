<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.ddtserver.mapper.PlayerMapper">

    <resultMap id="BaseResultMap" type="org.example.ddtserver.entity.Player">
        <id column="id" property="id"/>
        <result column="username" property="username"/>
        <result column="password" property="password"/>
        <result column="nickname" property="nickname"/>
        <result column="avatar" property="avatar"/>
        <result column="level" property="level"/>
        <result column="exp" property="exp"/>
        <result column="gold" property="gold"/>
        <result column="diamond" property="diamond"/>
        <result column="status" property="status"/>
        <result column="last_login_time" property="lastLoginTime"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="selectByUsername" resultMap="BaseResultMap">
        SELECT id, username, password, nickname, avatar, level, exp, gold, diamond, status,
               last_login_time, create_time, update_time
        FROM player
        WHERE username = #{username}
        LIMIT 1
    </select>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT id, username, password, nickname, avatar, level, exp, gold, diamond, status,
               last_login_time, create_time, update_time
        FROM player
        WHERE id = #{id}
        LIMIT 1
    </select>

    <update id="updateLastLoginTime">
        UPDATE player
        SET last_login_time = #{time}
        WHERE id = #{id}
    </update>
</mapper>
